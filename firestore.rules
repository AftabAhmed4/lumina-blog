rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email.lower() == 'aftabahmedcbspakistan@gmail.com'.lower();
    }

    function isValidUrl(url) {
      return url == "" || (url is string &&
             url.size() >= 1 &&
             (url.matches('^https://.*') || url.matches('^http://.*') || url.matches('^/.*')));
    }

    function isValidPost(data) {
      return data.title is string &&
             data.title.size() > 0 &&
             data.title.size() <= 150 &&

             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() <= 60000 &&

             // metadata
             (!('imageURL' in data) || data.imageURL == null || isValidUrl(data.imageURL)) &&
             (!('audioURL' in data) || data.audioURL == null || isValidUrl(data.audioURL)) &&

             data.userId is string &&

             data.status is string &&
             data.status in ['published', 'draft'] &&

             data.category is string;
             // Simplified category check to avoid mismatch between UI and Rules
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) ||
                    (isAuthenticated() && (
                      isOwner(resource.data.userId) || 
                      isAdmin() ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'views', 'commentsCount'])
                    ));
      allow delete: if isOwner(resource.data.userId) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() >= 1;
        allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.userId));
      }
    }
  }
}